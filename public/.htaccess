# fenia.com.ar — Hostinger (LiteSpeed / Apache) configuration.
# See docs/adr/ADR-023-htaccess-hosting-config.md for rationale.
#
# Astro copies everything in public/ verbatim to the root of dist/ at build
# time, so this file ships as /.htaccess in the publish directory. The CI
# Deploy job then uploads it via FTPS to the Hostinger document root.
#
# Compatibility: written in standard Apache directives; LiteSpeed (Hostinger's
# default in 2026) parses them natively. No LSCache-specific directives are
# used to keep this portable.

# ─────────────────────────────────────────────────────────────────────────────
# Force HTTPS (redirect plain HTTP to TLS)
# ─────────────────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>

# ─────────────────────────────────────────────────────────────────────────────
# Security headers
# CSP retains 'unsafe-inline' for script-src and style-src — documented
# technical debt linked to ADR-004 (Tailwind migration) and ADR-023.
# Tighten when ADR-004 closes and inline scripts are externalized.
# ─────────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
  Header always set X-Frame-Options "DENY"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; media-src 'self'; connect-src 'self'; frame-src 'self' https://tally.so https://*.tally.so; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
</IfModule>

# ─────────────────────────────────────────────────────────────────────────────
# Cache policy
# Astro fingerprints assets in /_astro with content hashes → safe to cache
# forever. Hand-managed files in /images and HTML pages get shorter caches.
# ─────────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Hashed Astro assets — long cache, immutable. Filename changes on rebuild.
  <FilesMatch "\.(css|js|woff2|woff|ttf|otf|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Hand-managed media — week-long cache. Bust by renaming.
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|mp4|webm)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # HTML / sitemap / robots — hour-long cache. Keeps content updates visible.
  <FilesMatch "\.(html|xml|txt)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# ─────────────────────────────────────────────────────────────────────────────
# Compression
# LiteSpeed handles brotli/gzip automatically; this block keeps the file
# correct under classic Apache as well.
# ─────────────────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript text/xml text/plain
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE font/woff2 image/svg+xml
</IfModule>

# ─────────────────────────────────────────────────────────────────────────────
# Custom 404 — Astro emits dist/404.html
# ─────────────────────────────────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ─────────────────────────────────────────────────────────────────────────────
# Hardening
# ─────────────────────────────────────────────────────────────────────────────
# Disable directory listing
Options -Indexes
# Don't reveal Apache/LiteSpeed version
ServerSignature Off
