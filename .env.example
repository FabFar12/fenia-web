# ─────────────────────────────────────────────────────────────────────────────
# fenia-web — Environment variables example
# ─────────────────────────────────────────────────────────────────────────────
# Currently the site is fully static and requires NO environment variables
# to build or run. This file exists as a placeholder so that future additions
# (analytics keys, form-submission endpoints, payment integrations) have a
# single documented source of truth.
#
# Copy this file to `.env` (which is gitignored) and fill in real values
# only if/when the corresponding feature is introduced.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site identity ────────────────────────────────────────────────────────────
# Canonical production URL. Used for sitemap.xml, robots.txt, OG tags.
# PUBLIC_SITE_URL=https://fenia.com.ar

# ── Analytics (not yet wired) ────────────────────────────────────────────────
# Plausible: privacy-first, GDPR/LGPD-friendly. Recommended over GA.
# PUBLIC_PLAUSIBLE_DOMAIN=fenia.com.ar
#
# Google Analytics 4 fallback (only if Plausible is not chosen):
# PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Error tracking (not yet wired) ───────────────────────────────────────────
# Sentry: capture client-side JS errors. Free tier is enough for this site.
# PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Testimonial submission (see ADR-005) ─────────────────────────────────────
# Tally form embed URL for /dejanos-tu-testimonio
# When this is set, the page automatically embeds the form; when unset, the
# page shows a fallback inviting submission via WhatsApp.
# PUBLIC_TALLY_TESTIMONIAL_FORM_URL=https://tally.so/r/xxxxxx

# ── Email contact (currently unused; conversion is via WhatsApp) ─────────────
# PUBLIC_CONTACT_EMAIL=hola@fenia.com.ar
