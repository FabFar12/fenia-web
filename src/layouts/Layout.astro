---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { siteMeta, whatsapp, socials } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = `${siteMeta.name} — ${siteMeta.tagline}`,
  description = siteMeta.description,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteMeta.prodUrl).toString();

// Schema.org structured data — Organization + ProfessionalService.
// Improves how FENIA appears in Google's Knowledge Panel and rich results.
// See docs/adr/ADR-009-seo-structured-data.md
const sameAsLinks = [socials.instagram.url, socials.linkedin.url, socials.youtube.url].filter(
  (u): u is string => typeof u === 'string' && u.length > 0,
);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${siteMeta.prodUrl}/#organization`,
  name: siteMeta.name,
  alternateName: siteMeta.fullName,
  description: siteMeta.description,
  url: siteMeta.prodUrl,
  telephone: `+${whatsapp.phone}`,
  inLanguage: siteMeta.locale,
  areaServed: { '@type': 'Country', name: 'Argentina' },
  knowsAbout: [
    'Neurociencias aplicadas',
    'Pensamiento estratégico',
    'Inteligencia artificial aplicada',
    'Gestión emocional',
    'Liderazgo',
    'Bienestar organizacional',
  ],
  ...(sameAsLinks.length > 0 ? { sameAs: sameAsLinks } : {}),
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0B1A2E" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <!-- Schema.org structured data. See ADR-009. -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Astro View Transitions — smooth cross-page transitions. See ADR-008. -->
    <ClientRouter />
  </head>
  <body>
    <!-- Pack 3: scroll progress bar driven by animations.ts -->
    <div id="scroll-progress" aria-hidden="true"></div>
    <!-- Pack v2.6: section sticky label, populated by animations.ts -->
    <div id="section-label" aria-hidden="true"></div>
    <slot />

    <!-- Pack 1 + Pack 3 + Pack v2 animation runtime — bundled by Astro -->
    <script>
      import '../scripts/animations';
    </script>
  </body>
</html>