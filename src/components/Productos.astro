---
// Productos.astro — Sección de productos digitales FENIA
// Reads from src/content/products/ via Astro Content Collections.
// Status 'draft' and 'archived' are hidden. 'coming-soon' shows a "PRÓXIMAMENTE" suffix.
// See: docs/ai-context/content-model.md and docs/adr/ADR-003-content-layer.md
import { getCollection } from 'astro:content';
import { whatsapp } from '../data/site';

const allProducts = await getCollection('products');
const products = allProducts
  .filter((p) => p.data.status === 'live' || p.data.status === 'coming-soon')
  .sort((a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime());

const accentText = (a: 'cyan' | 'coral') => (a === 'cyan' ? '#00B4D8' : '#E8573D');
const accentBg = (a: 'cyan' | 'coral') => (a === 'cyan' ? 'rgba(0,180,216,0.1)' : 'rgba(232,87,61,0.1)');

const customRequestUrl = whatsapp.url('Hola FENIA, necesito un recurso personalizado para mi equipo u organización');
---

<section id="productos" style="background:#0B1A2E;position:relative;overflow:hidden;">
  <div style="position:absolute;top:30%;right:10%;width:400px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(232,87,61,0.04) 0%,transparent 70%);pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;padding:100px 48px;position:relative;z-index:2;">
    <!-- Header -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;margin-bottom:56px;align-items:end;">
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);margin-bottom:20px;">
          <div style="width:5px;height:5px;border-radius:50%;background:#E8573D;"></div>
          <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.1em;font-family:'Plus Jakarta Sans',sans-serif;">Productos digitales</span>
        </div>
        <h2 style="font-size:38px;font-weight:800;line-height:1.1;color:#fff;letter-spacing:-0.03em;margin:0;font-family:'Plus Jakarta Sans',sans-serif;">
          Recursos listos para <span style="color:#00B4D8;">implementar</span>
        </h2>
      </div>
      <p style="font-size:15px;line-height:1.7;color:rgba(255,255,255,0.7);margin:0;font-family:'Plus Jakarta Sans',sans-serif;">
        Herramientas descargables basadas en evidencia, diseñadas para aplicar los principios de FENIA de forma autónoma e inmediata.
      </p>
    </div>

    <!-- Product cards -->
    <div class="reveal-stagger" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {products.map((product) => {
        const isComingSoon = product.data.status === 'coming-soon';
        const chipLabel = isComingSoon
          ? `${product.data.type} · Próximamente`
          : product.data.type;
        const footerLeft = isComingSoon ? 'En preparación' : 'Consultar';
        return (
          <div class="reveal hover-lift" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:18px;padding:32px 28px;display:flex;flex-direction:column;position:relative;overflow:hidden;">
            <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${accentText(product.data.accent)};opacity:0.5;`}></div>
            <span style={`display:inline-block;width:fit-content;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:4px 10px;border-radius:5px;background:${accentBg(product.data.accent)};color:${accentText(product.data.accent)};margin-bottom:18px;font-family:'Plus Jakarta Sans',sans-serif;`}>{chipLabel}</span>
            <h3 style="font-size:19px;font-weight:700;color:#fff;margin:0 0 12px 0;font-family:'Plus Jakarta Sans',sans-serif;">{product.data.title}</h3>
            <p style="font-size:14px;line-height:1.65;color:rgba(255,255,255,0.65);margin:0 0 28px 0;flex:1;font-family:'Plus Jakarta Sans',sans-serif;">{product.data.summary}</p>
            <div style="display:flex;justify-content:space-between;align-items:center;padding-top:20px;border-top:1px solid rgba(255,255,255,0.06);">
              <span style="font-size:13px;font-weight:700;color:rgba(255,255,255,0.7);font-family:'Plus Jakarta Sans',sans-serif;">{footerLeft}</span>
              <a href={product.data.cta.href} target="_blank" rel="noopener" style="font-size:12px;font-weight:600;padding:8px 18px;border-radius:7px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.03);color:#fff;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;">{product.data.cta.label} →</a>
            </div>
          </div>
        );
      })}
    </div>

    <!-- CTA bar -->
    <div style="margin-top:40px;padding:24px 32px;border-radius:14px;background:rgba(0,180,216,0.04);border:1px solid rgba(0,180,216,0.1);display:flex;justify-content:space-between;align-items:center;">
      <span style="font-size:15px;font-weight:600;color:rgba(255,255,255,0.8);font-family:'Plus Jakarta Sans',sans-serif;">¿Necesitás un recurso personalizado para tu equipo u organización?</span>
      <a class="cta-glow" href={customRequestUrl} target="_blank" rel="noopener" style="font-size:13px;font-weight:600;padding:10px 24px;border-radius:8px;border:none;background:#E8573D;color:#fff;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;box-shadow:0 4px 16px rgba(232,87,61,0.25);text-decoration:none;">Hablemos →</a>
    </div>
  </div>
</section>
