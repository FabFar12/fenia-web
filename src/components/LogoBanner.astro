---
// LogoBanner.astro — Banda superior con el vídeo del logo FENIA.
//
// Reemplaza al antiguo IntroLoader fullscreen bloqueante. El vídeo se
// reproduce una vez en silencio al cargar la página y se queda congelado
// en su último frame, comportándose como un "logo animado" sutil.
//
// Decisión arquitectónica: docs/adr/ADR-007-intro-video-as-logo-banner.md
---

<header class="logo-banner" aria-label="FENIA — logo">
  <div class="logo-banner-glow" aria-hidden="true"></div>
  <div class="logo-banner-inner">
    <span class="logo-banner-rule logo-banner-rule-left" aria-hidden="true"></span>
    <video
      class="logo-banner-video"
      src="/images/intro-fenia.mp4"
      autoplay
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
      tabindex="-1"
    ></video>
    <span class="logo-banner-rule logo-banner-rule-right" aria-hidden="true"></span>
  </div>
</header>

<style>
  .logo-banner {
    position: relative;
    width: 100%;
    background: #0B1A2E;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding: 18px 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    /* Subtle fade-in when the page first paints */
    animation: logo-banner-enter 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Soft radial cyan halo behind the logo */
  .logo-banner-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 180, 216, 0.08) 0%,
      rgba(0, 180, 216, 0.02) 35%,
      transparent 70%
    );
    pointer-events: none;
  }

  .logo-banner-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 28px;
    width: 100%;
    max-width: 720px;
  }

  /* Thin "horizon" lines fading from logo outwards */
  .logo-banner-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to var(--dir, right),
      transparent,
      rgba(0, 180, 216, 0.18) 45%,
      rgba(0, 180, 216, 0.28) 100%
    );
  }
  .logo-banner-rule-left { --dir: right; }
  .logo-banner-rule-right { --dir: left; background: linear-gradient(to left, transparent, rgba(0, 180, 216, 0.18) 45%, rgba(0, 180, 216, 0.28) 100%); }

  .logo-banner-video {
    display: block;
    height: 56px;
    width: auto;
    max-width: 240px;
    flex-shrink: 0;
    /* Slightly softer rendering, no controls visible */
    object-fit: contain;
    background: transparent;
    /* Subtle drop-shadow so the logo "floats" off the navy bg */
    filter: drop-shadow(0 4px 16px rgba(0, 180, 216, 0.15));
  }

  @keyframes logo-banner-enter {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .logo-banner { padding: 14px 16px; }
    .logo-banner-inner { gap: 16px; max-width: 100%; }
    .logo-banner-video { height: 42px; max-width: 180px; }
    .logo-banner-rule { display: none; } /* keep it clean on small screens */
  }

  /* Respect users that prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .logo-banner { animation: none; }
    .logo-banner-video { display: none; }
    /* fallback: show a styled wordmark if no animation allowed */
    .logo-banner::before {
      content: "FENIA";
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 22px;
      letter-spacing: -0.02em;
      color: #fff;
      z-index: 2;
    }
  }
</style>
