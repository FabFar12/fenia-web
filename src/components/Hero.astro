---
// Hero.astro — Sección hero principal de FENIA
import { whatsapp, heroStats, audiences } from '../data/site';
const waUrl = whatsapp.url();
const accentColor = (a: 'cyan' | 'coral') => (a === 'cyan' ? '#00B4D8' : '#E8573D');
---

<section id="inicio" style="background:#0B1A2E;position:relative;overflow:hidden;">
  <!-- HERO CONTENT -->
  <div style="position:relative;max-width:1200px;margin:0 auto;padding:80px 48px 60px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;min-height:78vh;">
    
    <!-- Network Background SVG -->
    <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="dg" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse"><circle cx="20" cy="20" r="0.6" fill="rgba(255,255,255,0.04)"/></pattern>
        <radialGradient id="gc" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(0,180,216,0.15)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
        <radialGradient id="go" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(232,87,61,0.06)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
      </defs>
      <rect width="1200" height="500" fill="url(#dg)"/>
      <ellipse cx="800" cy="200" rx="300" ry="200" fill="url(#gc)"/>
      <ellipse cx="400" cy="350" rx="200" ry="150" fill="url(#go)"/>
      <!-- Connection lines -->
      <line x1="680" y1="120" x2="750" y2="200" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="750" y1="200" x2="820" y2="150" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="820" y1="150" x2="900" y2="220" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="750" y1="200" x2="780" y2="300" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="820" y1="150" x2="850" y2="80" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="900" y1="220" x2="950" y2="160" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="780" y1="300" x2="720" y2="350" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="900" y1="220" x2="1000" y2="280" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="680" y1="120" x2="620" y2="250" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="950" y1="160" x2="1050" y2="120" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="850" y1="80" x2="950" y2="160" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <line x1="720" y1="350" x2="620" y2="250" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1"/>
      <!-- Nodes with glow -->
      <circle cx="680" cy="120" r="9" fill="#00B4D8" fill-opacity="0.032"/><circle cx="680" cy="120" r="3" fill="#00B4D8" fill-opacity="0.4"/>
      <circle cx="750" cy="200" r="12" fill="#00B4D8" fill-opacity="0.048"/><circle cx="750" cy="200" r="4" fill="#00B4D8" fill-opacity="0.6"/>
      <circle cx="820" cy="150" r="7.5" fill="#00B4D8" fill-opacity="0.024"/><circle cx="820" cy="150" r="2.5" fill="#00B4D8" fill-opacity="0.3"/>
      <circle cx="900" cy="220" r="10.5" fill="#00B4D8" fill-opacity="0.04"/><circle cx="900" cy="220" r="3.5" fill="#00B4D8" fill-opacity="0.5"/>
      <circle cx="780" cy="300" r="9" fill="#00B4D8" fill-opacity="0.028"/><circle cx="780" cy="300" r="3" fill="#00B4D8" fill-opacity="0.35"/>
      <circle cx="850" cy="80" r="6" fill="#00B4D8" fill-opacity="0.02"/><circle cx="850" cy="80" r="2" fill="#00B4D8" fill-opacity="0.25"/>
      <circle cx="950" cy="160" r="9" fill="#00B4D8" fill-opacity="0.032"/><circle cx="950" cy="160" r="3" fill="#00B4D8" fill-opacity="0.4"/>
      <circle cx="720" cy="350" r="7.5" fill="#00B4D8" fill-opacity="0.024"/><circle cx="720" cy="350" r="2.5" fill="#00B4D8" fill-opacity="0.3"/>
      <circle cx="1000" cy="280" r="6" fill="#00B4D8" fill-opacity="0.016"/><circle cx="1000" cy="280" r="2" fill="#00B4D8" fill-opacity="0.2"/>
      <circle cx="620" cy="250" r="6" fill="#00B4D8" fill-opacity="0.016"/><circle cx="620" cy="250" r="2" fill="#00B4D8" fill-opacity="0.2"/>
      <circle cx="1050" cy="120" r="9" fill="#00B4D8" fill-opacity="0.024"/><circle cx="1050" cy="120" r="3" fill="#00B4D8" fill-opacity="0.3"/>
      <circle cx="960" cy="350" r="7.5" fill="#00B4D8" fill-opacity="0.02"/><circle cx="960" cy="350" r="2.5" fill="#00B4D8" fill-opacity="0.25"/>
    </svg>

    <!-- Left: Copy -->
    <div style="position:relative;z-index:2;">
      <div class="hero-badge" style="display:inline-flex;align-items:center;gap:8px;padding:6px 18px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);margin-bottom:32px;">
        <div style="width:6px;height:6px;border-radius:50%;background:#00B4D8;box-shadow:0 0 8px #00B4D8;"></div>
        <span style="font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.08em;font-family:'Plus Jakarta Sans',sans-serif;">Consultoría · Formación · IA Aplicada</span>
      </div>

      <h1 style="font-size:50px;font-weight:800;line-height:1.08;color:#fff;letter-spacing:-0.03em;margin:0 0 22px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Estrategia e<br/>inteligencia<br/>
        <span style="background:linear-gradient(135deg,#00B4D8,#00D4AA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">aumentada</span>
      </h1>

      <p style="font-size:18px;font-weight:600;line-height:1.5;color:rgba(0,180,216,0.85);max-width:440px;margin:0 0 16px 0;font-family:'Plus Jakarta Sans',sans-serif;letter-spacing:-0.01em;">
        Pensar mejor. Decidir mejor.<br/>Actuar con Inteligencia Aumentada.
      </p>

      <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.45);max-width:420px;margin:0 0 36px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Articulamos neurociencias, gestión emocional y pensamiento estratégico con inteligencia artificial para transformar profesionales, equipos y organizaciones.
      </p>

      <div style="display:flex;gap:12px;margin-bottom:48px;">
        <a href={waUrl} target="_blank" rel="noopener" style="font-size:14.5px;font-weight:600;padding:13px 30px;border-radius:10px;border:none;background:#E8573D;color:#fff;cursor:pointer;box-shadow:0 4px 20px rgba(232,87,61,0.3);font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;">Solicitar un turno</a>
        <a href="#productos" style="font-size:14.5px;font-weight:600;padding:13px 30px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.03);color:#fff;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;">Ver próximos productos</a>
      </div>

      <div style="display:flex;gap:40px;">
        {heroStats.map((stat) => (
          <div>
            <div style="font-size:24px;font-weight:800;color:#00B4D8;letter-spacing:-0.02em;font-family:'Plus Jakarta Sans',sans-serif;">{stat.value}</div>
            <div style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.3);letter-spacing:0.02em;margin-top:2px;font-family:'Plus Jakarta Sans',sans-serif;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Service cards -->
    <div style="position:relative;z-index:2;height:420px;">
      <!-- Card 1: Consultoría -->
      <div class="service-card" style="position:absolute;top:0;left:20px;background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:24px 22px;width:220px;box-shadow:0 4px 20px rgba(0,0,0,0.15);">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:16px;color:rgba(255,255,255,0.4);margin-bottom:14px;">◇</div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin:0 0 6px 0;">Consultoría estratégica</h3>
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;line-height:1.5;color:rgba(255,255,255,0.4);margin:0;">Diagnóstico, diseño e implementación de soluciones organizacionales</p>
      </div>
      <!-- Card 2: Capacitación -->
      <div class="service-card" style="position:absolute;top:60px;left:260px;background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:24px 22px;width:220px;box-shadow:0 4px 20px rgba(0,0,0,0.15);">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:16px;color:rgba(255,255,255,0.4);margin-bottom:14px;">△</div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin:0 0 6px 0;">Capacitación</h3>
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;line-height:1.5;color:rgba(255,255,255,0.4);margin:0;">Liderazgo, gestión emocional y pensamiento estratégico</p>
      </div>
      <!-- Card 3: IA aplicada (accent) -->
      <div class="service-card" style="position:absolute;top:190px;left:40px;background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:1px solid rgba(0,180,216,0.2);border-radius:16px;padding:24px 22px;width:220px;box-shadow:0 8px 32px rgba(0,180,216,0.08);">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(0,180,216,0.1);border:1px solid rgba(0,180,216,0.25);display:flex;align-items:center;justify-content:center;font-size:16px;color:#00B4D8;margin-bottom:14px;">○</div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin:0 0 6px 0;">IA aplicada</h3>
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;line-height:1.5;color:rgba(255,255,255,0.4);margin:0;">Integración de herramientas de inteligencia artificial en procesos reales</p>
      </div>
      <!-- Card 4: Productos -->
      <div class="service-card" style="position:absolute;top:250px;left:280px;background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:24px 22px;width:220px;box-shadow:0 4px 20px rgba(0,0,0,0.15);">
        <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:16px;color:rgba(255,255,255,0.4);margin-bottom:14px;">□</div>
        <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin:0 0 6px 0;">Productos digitales</h3>
        <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;line-height:1.5;color:rgba(255,255,255,0.4);margin:0;">Recursos descargables listos para aplicar en tu práctica</p>
      </div>
      <!-- Dashed connection lines between cards -->
      <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;">
        <line x1="140" y1="95" x2="270" y2="80" stroke="#00B4D8" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="160" y1="200" x2="160" y2="210" stroke="#00B4D8" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="380" y1="175" x2="400" y2="260" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1" stroke-dasharray="4 4"/>
      </svg>
    </div>
  </div>

  <!-- Pillars bar -->
  <div style="max-width:1200px;margin:0 auto;padding:0 48px;">
    <div style="border-top:1px solid rgba(255,255,255,0.06);padding:28px 0;display:flex;justify-content:space-between;align-items:center;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:14px;color:rgba(255,255,255,0.15);">⬡</span>
        <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.3);font-family:'Plus Jakarta Sans',sans-serif;">Pensamiento estratégico</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:14px;color:#00B4D8;">◈</span>
        <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);font-family:'Plus Jakarta Sans',sans-serif;">Neuro-inteligencia aplicada</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:14px;color:rgba(255,255,255,0.15);">⬢</span>
        <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.3);font-family:'Plus Jakarta Sans',sans-serif;">Gestión emocional</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:14px;color:rgba(255,255,255,0.15);">◉</span>
        <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.3);font-family:'Plus Jakarta Sans',sans-serif;">Impacto real y escalable</span>
      </div>
    </div>
  </div>

  <!-- Audience cards -->
  <div style="max-width:1200px;margin:0 auto;padding:48px 48px 80px;">
    <div style="text-align:center;margin-bottom:40px;">
      <h2 style="font-size:32px;font-weight:800;color:#fff;letter-spacing:-0.02em;margin:0 0 12px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Una nueva forma de integrar estrategia, <span style="color:#00B4D8;">tecnología</span> y desarrollo humano
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.4);max-width:500px;margin:0 auto;font-family:'Plus Jakarta Sans',sans-serif;">Elegí el camino que mejor se adapta a tus necesidades</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {audiences.map((aud) => (
        <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:32px 28px;position:relative;overflow:hidden;">
          <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${accentColor(aud.accent)};opacity:0.5;`}></div>
          <h3 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 10px 0;font-family:'Plus Jakarta Sans',sans-serif;">{aud.title}</h3>
          <p style="font-size:14px;line-height:1.6;color:rgba(255,255,255,0.4);margin:0 0 24px 0;font-family:'Plus Jakarta Sans',sans-serif;">{aud.summary}</p>
          <a href="#servicios" style={`font-size:13px;font-weight:600;color:${accentColor(aud.accent)};cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;`}>Ver soluciones →</a>
        </div>
      ))}
    </div>
  </div>
</section>