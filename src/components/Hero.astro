---
// Hero.astro — Sección hero principal de FENIA
import { whatsapp, heroStats, audiences, services } from '../data/site';
import NeuralNetwork3D from './NeuralNetwork3D.jsx';
const waUrl = whatsapp.url();
const accentColor = (a: 'cyan' | 'coral') => (a === 'cyan' ? '#00B4D8' : '#E8573D');

// Right-column floating cards: one per service line.
// Positions hand-tuned to recreate the scattered visual rhythm of the original 4 cards.
const cardPositions = [
  { top: 0,   left: 20,  highlight: false },
  { top: 60,  left: 260, highlight: false },
  { top: 190, left: 40,  highlight: true  },
  { top: 250, left: 280, highlight: false },
];
const heroServiceCards = services.map((s, i) => ({
  slug: s.slug,
  icon: s.icon,
  title: s.title,
  subtitle: s.subtitle,
  pos: cardPositions[i] ?? cardPositions[0],
}));
---

<section id="inicio" style="background:#0B1A2E;position:relative;overflow:hidden;">
  <!-- HERO CONTENT -->
  <div style="position:relative;max-width:1200px;margin:0 auto;padding:80px 48px 60px;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;min-height:78vh;">
    
    <!-- Ambient background: dot grid + soft radial gradients (kept from legacy SVG; nodes/lines now rendered in 3D via NeuralNetwork3D) -->
    <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;z-index:0;" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="dg" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse"><circle cx="20" cy="20" r="0.6" fill="rgba(255,255,255,0.04)"/></pattern>
        <radialGradient id="gc" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(0,180,216,0.15)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
        <radialGradient id="go" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(232,87,61,0.06)"/><stop offset="100%" stop-color="transparent"/></radialGradient>
      </defs>
      <rect width="1200" height="500" fill="url(#dg)"/>
      <ellipse cx="800" cy="200" rx="300" ry="200" fill="url(#gc)"/>
      <ellipse cx="400" cy="350" rx="200" ry="150" fill="url(#go)"/>
    </svg>

    <!-- Pack 4: animated 3D neural network. Loaded as island when Hero is in viewport. -->
    <div style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;" aria-hidden="true">
      <NeuralNetwork3D client:visible />
    </div>

    <!-- Left: Copy -->
    <div class="reveal" style="position:relative;z-index:2;">
      <div class="hero-badge" style="display:inline-flex;align-items:center;gap:8px;padding:6px 18px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);margin-bottom:32px;">
        <div style="width:6px;height:6px;border-radius:50%;background:#00B4D8;box-shadow:0 0 8px #00B4D8;"></div>
        <span style="font-size:11.5px;font-weight:600;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.08em;font-family:'Plus Jakarta Sans',sans-serif;">Consultoría · Formación · IA Aplicada</span>
      </div>

      <h1 style="font-size:50px;font-weight:800;line-height:1.08;color:#fff;letter-spacing:-0.03em;margin:0 0 22px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Estrategia e<br/>inteligencia<br/>
        <span class="gradient-anim">aumentada</span>
      </h1>

      <p style="font-size:18px;font-weight:600;line-height:1.5;color:rgba(0,180,216,0.9);max-width:440px;margin:0 0 16px 0;font-family:'Plus Jakarta Sans',sans-serif;letter-spacing:-0.01em;">
        Pensar mejor. Decidir mejor.<br/>Actuar con Inteligencia Aumentada.
      </p>

      <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.7);max-width:420px;margin:0 0 36px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Articulamos neurociencias, gestión emocional y pensamiento estratégico con inteligencia artificial para transformar profesionales, equipos y organizaciones.
      </p>

      <div style="display:flex;gap:12px;margin-bottom:48px;">
        <a class="cta-glow cta-magnetic" href={waUrl} target="_blank" rel="noopener" style="font-size:14.5px;font-weight:600;padding:13px 30px;border-radius:10px;border:none;background:#E8573D;color:#fff;cursor:pointer;box-shadow:0 4px 20px rgba(232,87,61,0.3);font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;">Solicitar un turno</a>
        <a href="#productos" style="font-size:14.5px;font-weight:600;padding:13px 30px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.03);color:#fff;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;">Ver próximos productos</a>
      </div>

      <div style="display:flex;gap:40px;">
        {heroStats.map((stat) => (
          <div>
            <div data-counter={stat.value} style="font-size:24px;font-weight:800;color:#00B4D8;letter-spacing:-0.02em;font-family:'Plus Jakarta Sans',sans-serif;">{stat.value}</div>
            <div style="font-size:11px;font-weight:500;color:rgba(255,255,255,0.3);letter-spacing:0.02em;margin-top:2px;font-family:'Plus Jakarta Sans',sans-serif;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Service cards (float-animated + tilt on hover + click → corresponding Servicios tab) -->
    <div style="position:relative;z-index:2;height:420px;">
      {heroServiceCards.map((card, i) => (
        <a
          class="hero-svc-float"
          data-service-slug={card.slug}
          href="#servicios"
          style={`position:absolute;top:${card.pos.top}px;left:${card.pos.left}px;text-decoration:none;display:block;animation-delay:${i * 0.6}s;`}
          aria-label={`Ir al servicio: ${card.title}`}
        >
          <div
            class="hero-svc-card tilt-card"
            style={`background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:1px solid ${card.pos.highlight ? 'rgba(0,180,216,0.2)' : 'rgba(255,255,255,0.06)'};border-radius:16px;padding:24px 22px;width:220px;box-shadow:${card.pos.highlight ? '0 8px 32px rgba(0,180,216,0.08)' : '0 4px 20px rgba(0,0,0,0.15)'};`}
          >
            <div
              class="hero-svc-icon"
              aria-hidden="true"
              style={`width:36px;height:36px;border-radius:10px;background:${card.pos.highlight ? 'rgba(0,180,216,0.1)' : 'rgba(255,255,255,0.04)'};border:1px solid ${card.pos.highlight ? 'rgba(0,180,216,0.25)' : 'rgba(255,255,255,0.08)'};display:flex;align-items:center;justify-content:center;font-size:16px;color:${card.pos.highlight ? '#00B4D8' : 'rgba(255,255,255,0.45)'};margin-bottom:14px;`}
            >{card.icon}</div>
            <h3 style="font-family:'Plus Jakarta Sans',sans-serif;font-size:14px;font-weight:700;color:#fff;margin:0 0 6px 0;">{card.title}</h3>
            <p style="font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;line-height:1.5;color:rgba(255,255,255,0.55);margin:0;">{card.subtitle}</p>
          </div>
        </a>
      ))}
      <!-- Dashed connection lines between cards -->
      <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;" aria-hidden="true">
        <line x1="140" y1="95" x2="270" y2="80" stroke="#00B4D8" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="160" y1="200" x2="160" y2="210" stroke="#00B4D8" stroke-opacity="0.1" stroke-width="1" stroke-dasharray="4 4"/>
        <line x1="380" y1="175" x2="400" y2="260" stroke="#00B4D8" stroke-opacity="0.08" stroke-width="1" stroke-dasharray="4 4"/>
      </svg>
    </div>
  </div>

  <!-- Audience cards -->
  <div style="max-width:1200px;margin:0 auto;padding:48px 48px 80px;">
    <div style="text-align:center;margin-bottom:40px;">
      <h2 style="font-size:32px;font-weight:800;color:#fff;letter-spacing:-0.02em;margin:0 0 12px 0;font-family:'Plus Jakarta Sans',sans-serif;">
        Una nueva forma de integrar estrategia, <span style="color:#00B4D8;">tecnología</span> y desarrollo humano
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.65);max-width:500px;margin:0 auto;font-family:'Plus Jakarta Sans',sans-serif;">Elegí el camino que mejor se adapta a tus necesidades</p>
    </div>
    <div class="reveal-stagger" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {audiences.map((aud) => (
        <div class="reveal hover-lift" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:16px;padding:32px 28px;position:relative;overflow:hidden;">
          <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:${accentColor(aud.accent)};opacity:0.5;`}></div>
          <h3 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 10px 0;font-family:'Plus Jakarta Sans',sans-serif;">{aud.title}</h3>
          <p style="font-size:14px;line-height:1.6;color:rgba(255,255,255,0.65);margin:0 0 24px 0;font-family:'Plus Jakarta Sans',sans-serif;">{aud.summary}</p>
          <a href="#servicios" style={`font-size:13px;font-weight:600;color:${accentColor(aud.accent)};cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;text-decoration:none;`}>Ver soluciones →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Click on a Hero floating service card → dispatch a custom event that
  // Servicios.jsx listens to in order to select the matching tab. The href
  // anchor (`#servicios`) handles the smooth scroll to the section; this
  // event picks the right tab on arrival.
  document.querySelectorAll('.hero-svc-float[data-service-slug]').forEach((el) => {
    el.addEventListener('click', () => {
      const slug = (el as HTMLElement).dataset.serviceSlug;
      if (slug) {
        window.dispatchEvent(new CustomEvent('fenia:select-service', { detail: { slug } }));
      }
    });
  });
</script>