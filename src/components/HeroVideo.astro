---
// HeroVideo.astro — Centerpiece logo showcase for the home page.
//
// Originally housed an animated intro video; since 2026-05-26 it serves a
// static `main-logo.png` on a light "plate" so the wordmark (which is dark
// navy by design) reads cleanly on the dark page background.
//
// Component name kept as `HeroVideo` for git continuity; the visual contract
// is the same (centered brand element, ambient cyan halo, horizon rules).
//
// See ADR-026 (current) and ADR-007 (superseded — intro video version).
---

<section class="hero-video" aria-label="FENIA — logo">
  <div class="hero-video-glow" aria-hidden="true"></div>

  <div class="hero-video-stage">
    <span class="hero-video-rule hero-video-rule-left" aria-hidden="true"></span>

    <div class="hero-video-frame">
      <img
        class="hero-video-asset"
        src="/images/main-logo.png"
        alt="FENIA"
        width="780"
        height="280"
        loading="eager"
        decoding="async"
      />
    </div>

    <span class="hero-video-rule hero-video-rule-right" aria-hidden="true"></span>
  </div>
</section>

<style>
  .hero-video {
    position: relative;
    width: 100%;
    background: #0B1A2E;
    padding: 72px 24px 88px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    animation: hero-video-enter 900ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Ambient radial halo behind the plate — bigger and warmer than before
     so the plate reads as "lifted" rather than "pasted". */
  .hero-video-glow {
    position: absolute;
    inset: -20% 5%;
    z-index: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 180, 216, 0.22) 0%,
      rgba(0, 180, 216, 0.08) 35%,
      rgba(0, 180, 216, 0.02) 60%,
      transparent 78%
    );
    pointer-events: none;
  }

  /* Decorative dot-grid (preserved from the video version) */
  .hero-video::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 0.6px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    opacity: 0.6;
  }

  .hero-video-stage {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 40px;
    width: 100%;
    max-width: 1080px;
  }

  /* Thin "horizon" lines flanking the plate */
  .hero-video-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(0, 180, 216, 0.30) 55%,
      rgba(0, 180, 216, 0.55) 100%
    );
  }
  .hero-video-rule-right {
    background: linear-gradient(
      to left,
      transparent 0%,
      rgba(0, 180, 216, 0.30) 55%,
      rgba(0, 180, 216, 0.55) 100%
    );
  }

  /* The plate — light cream with a subtle gradient and layered shadows
     that give it depth without feeling like a sticker.
     Padding tightened 2026-05-26 (owner feedback: too much whitespace). */
  .hero-video-frame {
    position: relative;
    flex-shrink: 0;
    background: linear-gradient(180deg, #ffffff 0%, #f4faff 100%);
    border-radius: 22px;
    padding: 14px 24px;
    /* Layered shadows:
       1. 1px cyan ring → ties the plate to the brand
       2. 24px outward cyan glow → premium "object showcase" feel
       3. softer depth shadow → grounds it against the dark page  */
    box-shadow:
      0 0 0 1px rgba(0, 180, 216, 0.22),
      0 24px 64px -16px rgba(0, 180, 216, 0.45),
      0 10px 28px -8px rgba(0, 0, 0, 0.45);
    /* Subtle inner glow so the plate doesn't feel flat */
    overflow: hidden;
  }
  .hero-video-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      ellipse at top,
      rgba(0, 180, 216, 0.06) 0%,
      transparent 60%
    );
  }

  /* Logo size bumped 50% per owner feedback (168 → 252 desktop).
     Tablet and mobile scaled proportionally below. */
  .hero-video-asset {
    display: block;
    height: 252px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    position: relative;
    z-index: 1;
  }

  @keyframes hero-video-enter {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero-video { padding: 56px 20px 72px; }
    .hero-video-stage { gap: 28px; }
    .hero-video-frame { padding: 12px 18px; border-radius: 18px; }
    .hero-video-asset { height: 210px; }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero-video { padding: 44px 16px 60px; }
    .hero-video-stage { gap: 0; max-width: 100%; justify-content: center; }
    .hero-video-frame {
      padding: 10px 14px;
      border-radius: 16px;
      box-shadow:
        0 0 0 1px rgba(0, 180, 216, 0.22),
        0 14px 36px -12px rgba(0, 180, 216, 0.4),
        0 6px 18px -6px rgba(0, 0, 0, 0.5);
    }
    .hero-video-asset { height: 144px; max-width: 82vw; }
    .hero-video-rule { display: none; }
  }

  /* Reduced motion: skip the entry animation. The static PNG is fine
     without changes — no animated content to remove. */
  @media (prefers-reduced-motion: reduce) {
    .hero-video { animation: none; }
  }
</style>
