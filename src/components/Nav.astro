---
// Nav.astro
//
// Sticky top navigation. The brand block on the left is a single image —
// `main-logo-desc.png` (logo + wordmark + tagline) — rendered on a light
// plate so the dark-navy parts of the asset (which match the page
// background) remain legible. Treatment is the brand-consistent mini
// version of the hero plate (see ADR-026 and src/components/HeroVideo.astro).
import { whatsapp, navLinks, sectionHref } from '../data/site';
const waUrl = whatsapp.url();
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
---

<nav class="main-nav">
  <a
    href={isHome ? '#inicio' : '/'}
    class="nav-brand"
    aria-label="FENIA — inicio"
  >
    <img
      class="nav-brand-img"
      src="/images/main-logo-desc.png"
      alt="FENIA — Neuro-Inteligencia Aumentada"
      width="380"
      height="140"
      loading="eager"
      decoding="async"
    />
  </a>

  <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-label="Abrir menú de navegación" />
  <label for="nav-toggle" class="nav-hamburger" aria-label="Abrir menú de navegación" role="button" tabindex="0"><span></span><span></span><span></span></label>

  <div class="nav-links">
    {navLinks.map((link, i) => (
      <a href={sectionHref(link.href, pathname)} class={`nav-link${i === 0 ? ' nav-link-active' : ''}`}>{link.label}</a>
    ))}
    <a href={waUrl} target="_blank" rel="noopener noreferrer" class="nav-cta cta-magnetic">Solicitar un turno</a>
  </div>
</nav>

<style>
.main-nav{display:flex;align-items:center;justify-content:space-between;padding:14px 48px;border-bottom:1px solid rgba(255,255,255,0.05);position:sticky;top:0;z-index:50;background:rgba(11,26,46,0.95);backdrop-filter:blur(12px)}

/* The brand link is the plate.
   Mini version of the hero plate (ADR-026): same gradient + cyan ring +
   smaller glow, sized to fit comfortably in the 64-72px nav strip. */
.nav-brand{
  display:inline-flex;
  align-items:center;
  text-decoration:none;
  background:linear-gradient(180deg,#ffffff 0%,#f4faff 100%);
  border-radius:10px;
  padding:6px 14px;
  box-shadow:
    0 0 0 1px rgba(0,180,216,0.22),
    0 4px 14px -4px rgba(0,180,216,0.35);
  transition:transform 180ms cubic-bezier(0.16,1,0.3,1),box-shadow 180ms;
}
.nav-brand:hover{
  transform:translateY(-1px);
  box-shadow:
    0 0 0 1px rgba(0,180,216,0.34),
    0 6px 18px -4px rgba(0,180,216,0.50);
}
.nav-brand-img{
  display:block;
  height:40px;
  width:auto;
  max-width:240px;
  object-fit:contain;
}

.nav-links{display:flex;gap:32px;align-items:center}
.nav-link{font-size:13.5px;font-weight:500;color:rgba(255,255,255,0.45);text-decoration:none}
.nav-link-active{font-weight:600;color:#fff}
.nav-cta{font-size:13.5px;font-weight:600;padding:10px 24px;border-radius:9px;background:#E8573D;color:#fff;box-shadow:0 4px 16px rgba(232,87,61,0.3);text-decoration:none}
.nav-toggle-input{display:none}
.nav-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.nav-hamburger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px;transition:all 0.3s ease}

@media(max-width:768px){
  .main-nav{padding:10px 20px}
  .nav-brand{padding:5px 10px;border-radius:8px}
  .nav-brand-img{height:32px;max-width:180px}
  .nav-hamburger{display:flex}
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:rgba(11,26,46,0.98);backdrop-filter:blur(12px);flex-direction:column;padding:24px 20px;gap:0;border-bottom:1px solid rgba(255,255,255,0.08)}
  .nav-link,.nav-cta{padding:14px 0;width:100%;font-size:15px}
  .nav-link{border-bottom:1px solid rgba(255,255,255,0.05)}
  .nav-cta{margin-top:12px;text-align:center;padding:14px 24px}
  .nav-toggle-input:checked ~ .nav-links{display:flex}
  .nav-toggle-input:checked ~ .nav-hamburger span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
  .nav-toggle-input:checked ~ .nav-hamburger span:nth-child(2){opacity:0}
  .nav-toggle-input:checked ~ .nav-hamburger span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
}
</style>
