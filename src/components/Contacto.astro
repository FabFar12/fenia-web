---
// Contacto.astro
import { whatsapp, socials } from '../data/site';
const waUrl = whatsapp.url();
---

<section id="contacto" class="section-contacto">
  <div class="contacto-glow"></div>
  <div class="contacto-container">
    <div class="contacto-inner reveal">
      <div class="badge"><div class="badge-dot"></div><span class="badge-text">Contacto</span></div>
      <h2 class="contacto-title">Transformá ideas, equipos y procesos con una mirada <span class="text-cyan">estratégica y aumentada</span></h2>
      <p class="contacto-desc">Decí cómo gustás empezar una conversación: un servicio a medida, un producto listo para aplicar, o simplemente explorar opciones.</p>
      <div class="contacto-buttons">
        <a href={waUrl} target="_blank" rel="noopener" class="btn-coral cta-glow cta-magnetic">💬 Solicitar un turno</a>
        <a href="#productos" class="btn-outline">Ver próximos productos</a>
      </div>
      <div class="contacto-info">
        <div class="contacto-col">
          <div class="contacto-label">WhatsApp</div>
          <a href={`https://wa.me/${whatsapp.phone}`} target="_blank" rel="noopener" class="contacto-value">{whatsapp.displayPhone}</a>
          <div class="contacto-sub">Respuesta en menos de 24h</div>
        </div>
        <div class="contacto-col">
          <div class="contacto-label">Redes</div>
          <div class="contacto-value">{socials.instagram.handle}</div>
          <div class="contacto-sub">Instagram · LinkedIn</div>
        </div>
      </div>
      <div class="contacto-testimonial">
        <a href="/dejanos-tu-testimonio" class="contacto-testimonial-link">
          ¿Trabajaste con FENIA? Dejanos tu testimonio →
        </a>
      </div>
    </div>
  </div>
</section>
<style>
.section-contacto{background:#0B1A2E;position:relative;overflow:hidden}
.contacto-glow{position:absolute;bottom:20%;left:50%;transform:translateX(-50%);width:500px;height:300px;border-radius:50%;background:radial-gradient(ellipse,rgba(0,180,216,0.05) 0%,transparent 70%);pointer-events:none}
.contacto-container{max-width:1200px;margin:0 auto;padding:100px 48px;position:relative;z-index:2}
.contacto-inner{max-width:720px;margin:0 auto;text-align:center}
.badge{display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);margin-bottom:24px}
.badge-dot{width:5px;height:5px;border-radius:50%;background:#E8573D}
.badge-text{font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.1em}
.contacto-title{font-size:40px;font-weight:800;line-height:1.1;color:#fff;letter-spacing:-0.03em;margin:0 0 16px 0}
.text-cyan{color:#00B4D8}
.contacto-desc{font-size:16px;line-height:1.7;color:rgba(255,255,255,0.7);margin:0 0 44px 0}
.contacto-buttons{display:flex;gap:16px;justify-content:center;margin-bottom:56px}
.btn-coral{font-size:15px;font-weight:600;padding:16px 36px;border-radius:12px;background:#E8573D;color:#fff;cursor:pointer;box-shadow:0 6px 24px rgba(232,87,61,0.3);display:inline-flex;align-items:center;gap:10px;text-decoration:none}
.btn-outline{font-size:15px;font-weight:600;padding:16px 36px;border-radius:12px;border:1px solid rgba(255,255,255,0.12);background:rgba(255,255,255,0.03);color:#fff;cursor:pointer;text-decoration:none}
.contacto-info{display:grid;grid-template-columns:1fr 1fr;gap:20px;padding:32px 0;border-top:1px solid rgba(255,255,255,0.06)}
.contacto-testimonial{margin-top:28px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.06);text-align:center}
.contacto-testimonial-link{font-size:13px;font-weight:600;color:rgba(255,255,255,0.7);text-decoration:none;letter-spacing:0.01em}
.contacto-testimonial-link:hover{color:#00B4D8}
.contacto-col{text-align:center}
.contacto-label{font-size:11px;font-weight:700;color:#00B4D8;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px}
.contacto-value{font-size:15px;font-weight:600;color:#fff;text-decoration:none;display:block}
.contacto-sub{font-size:12px;color:rgba(255,255,255,0.55);margin-top:6px}
@media(max-width:768px){
.contacto-container{padding:60px 20px}
.contacto-title{font-size:28px}
.contacto-buttons{flex-direction:column;align-items:center}
.btn-coral,.btn-outline{width:100%;text-align:center;justify-content:center}
.contacto-info{grid-template-columns:1fr}
}
</style>
