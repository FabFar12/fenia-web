---
// Metodologia.astro — Sección de enfoque y metodología FENIA
import { methodologyPillars } from '../data/site';
---

<section id="metodologia" style="background:#0B1A2E;position:relative;overflow:hidden;">
  <!-- Dot grid -->
  <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;">
    <defs><pattern id="md" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse"><circle cx="24" cy="24" r="0.7" fill="rgba(255,255,255,0.03)"/></pattern></defs>
    <rect width="100%" height="100%" fill="url(#md)"/>
  </svg>

  <div style="max-width:1200px;margin:0 auto;padding:100px 48px;position:relative;z-index:2;">
    <!-- Header -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-bottom:72px;align-items:end;">
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);margin-bottom:20px;">
          <div style="width:5px;height:5px;border-radius:50%;background:#E8573D;"></div>
          <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.1em;font-family:'Plus Jakarta Sans',sans-serif;">Nuestro enfoque</span>
        </div>
        <h2 style="font-size:40px;font-weight:800;line-height:1.1;color:#fff;letter-spacing:-0.03em;margin:0;font-family:'Plus Jakarta Sans',sans-serif;">
          Una metodología que integra <span style="color:#00B4D8;">ciencia</span>, <span style="color:#00B4D8;">estrategia</span> y <span style="color:#00B4D8;">tecnología</span>
        </h2>
      </div>
      <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.7);margin:0;max-width:440px;font-family:'Plus Jakarta Sans',sans-serif;">
        No creemos en soluciones genéricas. Nuestro marco de trabajo combina cuatro dimensiones que se potencian mutuamente para generar transformaciones profundas y duraderas.
      </p>
    </div>

    <!-- Pillars (auto-cycle highlight + hover override; see ADR-012) -->
    <div class="meth-pillars reveal-stagger" style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;">
      <div style="position:absolute;top:52px;left:8%;right:8%;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,216,0.15),rgba(0,180,216,0.15),transparent);z-index:0;"></div>

      {methodologyPillars.map((pillar, i) => (
        <div class="meth-pillar reveal" data-pillar-index={i} style="padding:0 20px;position:relative;z-index:1;cursor:pointer;">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
            <div class="meth-pillar-num">
              {pillar.num}
              <div class="meth-pillar-dot"></div>
            </div>
          </div>
          <h3 class="meth-pillar-title">{pillar.title}</h3>
          <p class="meth-pillar-body">{pillar.body}</p>
          <div class="meth-pillar-rule"></div>
        </div>
      ))}
    </div>

    <!-- Integration block -->
    <div style="margin-top:80px;padding:40px;border-radius:20px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);display:grid;grid-template-columns:1fr auto 1fr;gap:48px;align-items:center;">
      <div>
        <h3 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 10px 0;font-family:'Plus Jakarta Sans',sans-serif;">No es consultoría tradicional.<br/>No es solo tecnología.</h3>
        <p style="font-size:15px;line-height:1.65;color:rgba(255,255,255,0.7);margin:0;font-family:'Plus Jakarta Sans',sans-serif;">Es un modelo integrador donde neurociencia, estrategia e IA convergen para producir resultados que ninguna disciplina aislada podría lograr.</p>
      </div>
      <!-- Atom-style convergence diagram with orbiting labels (ADR-015).
           Each electron lives inside a <g class="orbit-N"> whose CSS
           rotation sweeps it around the nucleus. A nested <g class="orbit-
           counter-N"> counter-rotates at the same speed in the opposite
           direction — net effect: the label TRANSLATES with the electron
           but stays UPRIGHT in screen space. Each electron is linked 1:1
           with a differentiator on the right via data-orbit-idx. -->
      <svg class="conv-diagram conv-atom" width="180" height="180" viewBox="0 0 160 160" aria-label="Diagrama atómico: 4 disciplinas orbitando el núcleo de FENIA">
        <!-- Faint orbital guides — slight stroke pulse for ambience -->
        <circle class="atom-ring" cx="80" cy="80" r="58" fill="none" stroke="rgba(0,180,216,0.10)" stroke-width="0.5" stroke-dasharray="2 4"/>
        <circle class="atom-ring" cx="80" cy="80" r="32" fill="none" stroke="rgba(0,180,216,0.08)" stroke-width="0.5" stroke-dasharray="2 4"/>

        <!-- Orbit 1 (innermost, R=30) — Diagnóstico -->
        <g class="orbit orbit-1" data-orbit-idx="0">
          <g class="orbit-counter orbit-counter-1">
            <circle class="electron-halo" cx="110" cy="80" r="9" fill="#00B4D8"/>
            <circle class="electron-core" cx="110" cy="80" r="4" fill="#00B4D8" data-orbit-idx="0"><title>Diagnóstico antes de solución</title></circle>
            <text class="electron-label" x="110" y="66" text-anchor="middle">Diagnóstico</text>
          </g>
        </g>

        <!-- Orbit 2 (R=42) — Evidencia -->
        <g class="orbit orbit-2" data-orbit-idx="1">
          <g class="orbit-counter orbit-counter-2">
            <circle class="electron-halo" cx="122" cy="80" r="10" fill="#00B4D8"/>
            <circle class="electron-core" cx="122" cy="80" r="4" fill="#00B4D8" data-orbit-idx="1"><title>Evidencia neurocientífica real</title></circle>
            <text class="electron-label" x="122" y="66" text-anchor="middle">Evidencia</text>
          </g>
        </g>

        <!-- Orbit 3 (R=54) — IA -->
        <g class="orbit orbit-3" data-orbit-idx="2">
          <g class="orbit-counter orbit-counter-3">
            <circle class="electron-halo" cx="134" cy="80" r="10" fill="#00B4D8"/>
            <circle class="electron-core" cx="134" cy="80" r="4" fill="#00B4D8" data-orbit-idx="2"><title>IA como potenciador, no reemplazo</title></circle>
            <text class="electron-label" x="134" y="66" text-anchor="middle">IA aplicada</text>
          </g>
        </g>

        <!-- Orbit 4 (outermost, R=64, coral) — Métricas -->
        <g class="orbit orbit-4" data-orbit-idx="3">
          <g class="orbit-counter orbit-counter-4">
            <circle class="electron-halo electron-halo-coral" cx="144" cy="80" r="9" fill="#E8573D"/>
            <circle class="electron-core electron-core-coral" cx="144" cy="80" r="3.5" fill="#E8573D" data-orbit-idx="3"><title>Métricas de impacto concretas</title></circle>
            <text class="electron-label" x="144" y="66" text-anchor="middle">Métricas</text>
          </g>
        </g>

        <!-- Nucleus -->
        <circle class="atom-nucleus-halo" cx="80" cy="80" r="14" fill="rgba(0,180,216,0.15)"/>
        <circle class="atom-nucleus-core" cx="80" cy="80" r="6.5" fill="#1FE3FF"/>
      </svg>
      <!-- Differentiators — linked 1:1 with the atom electrons (ADR-015).
           Auto-cycle + hover override; hovering a diff highlights its
           matching electron and vice-versa. -->
      <div class="conv-differentiators" style="display:flex;flex-direction:column;gap:16px;">
        <div class="conv-diff" data-diff-idx="0"><div class="conv-diff-dot"></div><span class="conv-diff-text">Diagnóstico antes de solución</span></div>
        <div class="conv-diff" data-diff-idx="1"><div class="conv-diff-dot"></div><span class="conv-diff-text">Evidencia neurocientífica real</span></div>
        <div class="conv-diff" data-diff-idx="2"><div class="conv-diff-dot"></div><span class="conv-diff-text">IA como potenciador, no reemplazo</span></div>
        <div class="conv-diff" data-diff-idx="3"><div class="conv-diff-dot"></div><span class="conv-diff-text">Métricas de impacto concretas</span></div>
      </div>
    </div>
  </div>
</section>