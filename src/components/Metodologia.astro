---
// Metodologia.astro — Sección de enfoque y metodología FENIA
import { methodologyPillars } from '../data/site';
---

<section id="metodologia" style="background:#0B1A2E;position:relative;overflow:hidden;">
  <!-- Dot grid -->
  <svg style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;">
    <defs><pattern id="md" x="0" y="0" width="48" height="48" patternUnits="userSpaceOnUse"><circle cx="24" cy="24" r="0.7" fill="rgba(255,255,255,0.03)"/></pattern></defs>
    <rect width="100%" height="100%" fill="url(#md)"/>
  </svg>

  <div style="max-width:1200px;margin:0 auto;padding:100px 48px;position:relative;z-index:2;">
    <!-- Header -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-bottom:72px;align-items:end;">
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);margin-bottom:20px;">
          <div style="width:5px;height:5px;border-radius:50%;background:#E8573D;"></div>
          <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.1em;font-family:'Plus Jakarta Sans',sans-serif;">Nuestro enfoque</span>
        </div>
        <h2 style="font-size:40px;font-weight:800;line-height:1.1;color:#fff;letter-spacing:-0.03em;margin:0;font-family:'Plus Jakarta Sans',sans-serif;">
          Una metodología que integra <span style="color:#00B4D8;">ciencia</span>, <span style="color:#00B4D8;">estrategia</span> y <span style="color:#00B4D8;">tecnología</span>
        </h2>
      </div>
      <p style="font-size:16px;line-height:1.7;color:rgba(255,255,255,0.4);margin:0;max-width:440px;font-family:'Plus Jakarta Sans',sans-serif;">
        No creemos en soluciones genéricas. Nuestro marco de trabajo combina cuatro dimensiones que se potencian mutuamente para generar transformaciones profundas y duraderas.
      </p>
    </div>

    <!-- Pillars -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;">
      <div style="position:absolute;top:52px;left:8%;right:8%;height:1px;background:linear-gradient(90deg,transparent,rgba(0,180,216,0.15),rgba(0,180,216,0.15),transparent);z-index:0;"></div>

      {methodologyPillars.map((pillar) => {
        const numBg = pillar.highlight ? 'rgba(0,180,216,0.1)' : 'rgba(255,255,255,0.03)';
        const numBorder = pillar.highlight ? 'rgba(0,180,216,0.25)' : 'rgba(255,255,255,0.06)';
        const numColor = pillar.highlight ? '#00B4D8' : 'rgba(255,255,255,0.25)';
        const dotBg = pillar.highlight ? '#00B4D8' : 'rgba(255,255,255,0.1)';
        return (
          <div style="padding:0 20px;position:relative;z-index:1;">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
              <div style={`width:44px;height:44px;border-radius:12px;background:${numBg};border:1px solid ${numBorder};display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;color:${numColor};font-family:'Plus Jakarta Sans',sans-serif;position:relative;`}>
                {pillar.num}<div style={`position:absolute;top:-4px;right:-4px;width:8px;height:8px;border-radius:50%;background:${dotBg};border:2px solid #0B1A2E;`}></div>
              </div>
            </div>
            <h3 style="font-size:17px;font-weight:700;color:#fff;margin:0 0 12px 0;font-family:'Plus Jakarta Sans',sans-serif;">{pillar.title}</h3>
            <p style="font-size:14px;line-height:1.65;color:rgba(255,255,255,0.38);margin:0;font-family:'Plus Jakarta Sans',sans-serif;">{pillar.body}</p>
            {pillar.highlight && (
              <div style="width:32px;height:2px;border-radius:1px;background:#00B4D8;margin-top:20px;opacity:0.6;"></div>
            )}
          </div>
        );
      })}
    </div>

    <!-- Integration block -->
    <div style="margin-top:80px;padding:40px;border-radius:20px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);display:grid;grid-template-columns:1fr auto 1fr;gap:48px;align-items:center;">
      <div>
        <h3 style="font-size:22px;font-weight:700;color:#fff;margin:0 0 10px 0;font-family:'Plus Jakarta Sans',sans-serif;">No es consultoría tradicional.<br/>No es solo tecnología.</h3>
        <p style="font-size:15px;line-height:1.65;color:rgba(255,255,255,0.4);margin:0;font-family:'Plus Jakarta Sans',sans-serif;">Es un modelo integrador donde neurociencia, estrategia e IA convergen para producir resultados que ninguna disciplina aislada podría lograr.</p>
      </div>
      <!-- Convergence diagram -->
      <svg width="140" height="140" viewBox="0 0 140 140">
        <circle cx="70" cy="70" r="60" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/><circle cx="70" cy="70" r="40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
        <line x1="35" y1="35" x2="70" y2="70" stroke="#00B4D8" stroke-width="1" opacity="0.2"/><line x1="105" y1="35" x2="70" y2="70" stroke="#00B4D8" stroke-width="1" opacity="0.2"/><line x1="70" y1="120" x2="70" y2="70" stroke="#00B4D8" stroke-width="1" opacity="0.2"/><line x1="20" y1="90" x2="70" y2="70" stroke="#E8573D" stroke-width="1" opacity="0.15"/>
        <circle cx="35" cy="35" r="5" fill="#00B4D8" opacity="0.5"/><circle cx="105" cy="35" r="5" fill="#00B4D8" opacity="0.4"/><circle cx="70" cy="120" r="5" fill="#00B4D8" opacity="0.3"/><circle cx="20" cy="90" r="4" fill="#E8573D" opacity="0.4"/>
        <circle cx="70" cy="70" r="12" fill="rgba(0,180,216,0.08)"/><circle cx="70" cy="70" r="6" fill="#00B4D8" opacity="0.8"/>
        <text x="22" y="28" font-size="8" fill="rgba(255,255,255,0.3)" font-family="'Plus Jakarta Sans',sans-serif" font-weight="600">Neuro</text>
        <text x="92" y="28" font-size="8" fill="rgba(255,255,255,0.3)" font-family="'Plus Jakarta Sans',sans-serif" font-weight="600">IA</text>
        <text x="54" y="136" font-size="8" fill="rgba(255,255,255,0.3)" font-family="'Plus Jakarta Sans',sans-serif" font-weight="600">Estrategia</text>
      </svg>
      <!-- Differentiators -->
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;"><div style="width:6px;height:6px;border-radius:50%;background:#00B4D8;flex-shrink:0;"></div><span style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.7);font-family:'Plus Jakarta Sans',sans-serif;">Diagnóstico antes de solución</span></div>
        <div style="display:flex;align-items:center;gap:12px;"><div style="width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.15);flex-shrink:0;"></div><span style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.35);font-family:'Plus Jakarta Sans',sans-serif;">Evidencia neurocientífica real</span></div>
        <div style="display:flex;align-items:center;gap:12px;"><div style="width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.15);flex-shrink:0;"></div><span style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.35);font-family:'Plus Jakarta Sans',sans-serif;">IA como potenciador, no reemplazo</span></div>
        <div style="display:flex;align-items:center;gap:12px;"><div style="width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.15);flex-shrink:0;"></div><span style="font-size:14px;font-weight:600;color:rgba(255,255,255,0.35);font-family:'Plus Jakarta Sans',sans-serif;">Métricas de impacto concretas</span></div>
      </div>
    </div>
  </div>
</section>