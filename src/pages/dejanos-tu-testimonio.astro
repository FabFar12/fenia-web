---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { whatsapp } from '../data/site';

const tallyUrl = import.meta.env.PUBLIC_TALLY_TESTIMONIAL_FORM_URL as string | undefined;
const waUrl = whatsapp.url('Hola FENIA, quiero dejar un testimonio sobre mi experiencia');
---

<Layout title="Dejanos tu testimonio — FENIA">
  <Nav />

  <main style="background:#0B1A2E;min-height:80vh;">
    <section style="max-width:760px;margin:0 auto;padding:100px 48px 80px;color:#fff;font-family:'Plus Jakarta Sans',sans-serif;">

      <div style="display:inline-flex;align-items:center;gap:8px;padding:5px 14px;border-radius:100px;border:1px solid rgba(255,255,255,0.08);margin-bottom:24px;">
        <div style="width:5px;height:5px;border-radius:50%;background:#00B4D8;box-shadow:0 0 8px #00B4D8;"></div>
        <span style="font-size:11px;font-weight:600;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.1em;">Testimonios</span>
      </div>

      <h1 style="font-size:40px;font-weight:800;line-height:1.1;letter-spacing:-0.03em;margin:0 0 16px 0;">
        Contanos tu experiencia con <span style="background:linear-gradient(135deg,#00B4D8,#00D4AA);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">FENIA</span>
      </h1>

      <p style="font-size:17px;line-height:1.65;color:rgba(255,255,255,0.65);margin:0 0 32px 0;max-width:560px;">
        Tu testimonio nos ayuda a mostrar a otras personas el impacto real de nuestro trabajo. Solo publicamos testimonios con consentimiento explícito y revisión humana.
      </p>

      {tallyUrl ? (
        <div style="margin-top:16px;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
          <iframe
            src={tallyUrl}
            width="100%"
            height="720"
            title="Formulario de testimonio — FENIA"
            style="display:block;background:transparent;border:0;"
            loading="lazy"
          ></iframe>
        </div>
      ) : (
        <div style="margin-top:16px;padding:32px;border-radius:16px;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.02);">
          <h2 style="font-size:18px;font-weight:700;margin:0 0 12px 0;color:#fff;">
            Estamos terminando el formulario público
          </h2>
          <p style="font-size:15px;line-height:1.65;color:rgba(255,255,255,0.65);margin:0 0 24px 0;">
            Mientras tanto, podés enviarnos tu testimonio directamente por WhatsApp. Lo revisaremos y, con tu autorización, lo publicaremos en la sección de Confianza con tu nombre, cargo y foto si quisieras incluirla.
          </p>
          <a href={waUrl} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:8px;font-size:14.5px;font-weight:600;padding:13px 28px;border-radius:10px;background:#E8573D;color:#fff;box-shadow:0 4px 20px rgba(232,87,61,0.3);text-decoration:none;">
            💬 Enviar testimonio por WhatsApp
          </a>
        </div>
      )}

      <hr style="border:none;border-top:1px solid rgba(255,255,255,0.06);margin:48px 0 32px 0;" />

      <h2 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 16px 0;">Qué pedimos en el formulario</h2>
      <ul style="font-size:14px;line-height:1.85;color:rgba(255,255,255,0.55);padding-left:20px;margin:0 0 32px 0;">
        <li>Tu nombre completo</li>
        <li>Tu cargo y empresa o proyecto</li>
        <li>LinkedIn (opcional, para que se vea que sos una persona real)</li>
        <li>Una foto tuya (opcional)</li>
        <li>Tu testimonio (lo que vivimos juntos, idealmente con un detalle concreto)</li>
        <li>Tu autorización explícita para publicarlo</li>
      </ul>

      <h2 style="font-size:18px;font-weight:700;color:#fff;margin:0 0 16px 0;">Qué hacemos con tu información</h2>
      <p style="font-size:14px;line-height:1.7;color:rgba(255,255,255,0.55);margin:0;">
        Tu testimonio se publica solo después de revisión humana y bajo tu consentimiento explícito.
        Nunca usamos tu información para otros fines y podés pedir que lo retiremos en cualquier momento escribiéndonos por WhatsApp.
      </p>

    </section>
  </main>

  <Footer />
</Layout>
