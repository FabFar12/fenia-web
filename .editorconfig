# https://editorconfig.org — keeps editor settings consistent across the team.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Preserve trailing spaces in Markdown — they create hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
